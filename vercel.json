{
  "version": 2,
  "routes": [
    {
      "src": "/src/assets/images/(.*)",
      "dest": "/src/assets/images/$1"
    },
    {
      "src": "/manifest.json",
      "dest": "/manifest.json"
    },
    {
      "src": "/sw.js",
      "dest": "/sw.js"
    },
    {
      "src": "/[^.]*",
      "dest": "/index.html"
    }
  ]
}
